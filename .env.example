# ─────────────────────────────────────────────────────────────
# KAIZEN Coaching — plantilla de credenciales para CONECTARSE y operar el backend.
# Copiá a .env.local (ignorado por git) y completá con los valores reales.
# Los valores reales NO se comitean. Dónde sale cada uno: ver docs/BACKEND.md.
# ─────────────────────────────────────────────────────────────

# --- Supabase (proyecto YOUR_PROJECT_REF) ---
# PAT personal para correr SQL vía Management API y desplegar Edge Functions.
# Crear en: Supabase Dashboard → Account → Access Tokens. Revocar al terminar.
SUPABASE_ACCESS_TOKEN=sbp_xxx
# Project ref (no es secreto)
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# --- ONVO Pay (procesador de pagos, LIVE) ---
# Dashboard ONVO → Producción → Developers → API Keys
ONVO_SECRET_KEY=onvo_live_secret_key_xxx        # secreto (solo backend)
ONVO_PUBLIC_KEY=onvo_live_publishable_key_xxx   # publishable (ya va inline en index.html)
ONVO_PRICE_ID=cmqmvadjn8ylwlh23yg0axr0e          # precio $50/mes live (público)
ONVO_WEBHOOK_SECRET=webhook_secret_xxx           # signing secret del webhook live

# --- Resend (correo transaccional) ---
RESEND_API_KEY=re_xxx
RESEND_FROM=Coach Kaizen - KAIZEN Coaching <hola@kaizencoaching.com>
RESEND_REPLY_TO=coachkaizen@gmail.com

# --- Interno ---
INVITE_INTERNAL_SECRET=xxx   # secreto compartido webhook→send-invite

# --- Admin del backoffice (para QA/login en /admin) ---
ADMIN_EMAIL=coachkaizen@gmail.com
ADMIN_PASSWORD=xxx
